spring:
  application:
    name: be

  datasource:
    url: jdbc:mysql://localhost:3306/cafe_db?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username:          # 본인 MySQL 계정
    password:          # 본인 MySQL 비밀번호
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    open-in-view: false
    hibernate:
      ddl-auto: update      # 개발 중에는 update, 배포 시 none으로 변경
    show-sql: true          # SQL 쿼리 콘솔에 출력
    properties:
      hibernate:
        format_sql: true    # SQL 보기 좋게 포맷팅

server:
  port: 8080

springdoc:
  swagger-ui:
    path: /swagger-ui.html
    operations-sorter: method
    tags-sorter: alpha
  api-docs:
    path: /v3/api-docs